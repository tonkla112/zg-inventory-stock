{
  "permissions": {
    "allow": [
      "WebFetch(domain:api.anthropic.com)",
      "Read(//private/tmp/zg-design/**)",
      "Bash(gunzip -k design.gz)",
      "Bash(mkdir -p extracted)",
      "Bash(tar -xf design -C extracted)",
      "Bash(python3 -m http.server 8765)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} — %{size_download} bytes\\\\n\" http://localhost:8765/index.html)",
      "Bash(curl -s -o /dev/null -w \"app.jsx: %{http_code}\\\\n\" http://localhost:8765/src/app.jsx)",
      "Bash(open http://localhost:8765/)"
    ]
  }
}
